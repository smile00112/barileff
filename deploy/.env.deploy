# =============================================================
# Bagisto Bare-Metal Deploy — Variables
# Copy this file to .env.deploy and fill in your values.
# =============================================================

# --- Application ---
APP_DIR=/var/www/bagisto
APP_USER=www-data
APP_REPO=https://github.com/your-org/your-repo.git
APP_BRANCH=main
APP_ENV=production
APP_DEBUG=false
APP_URL=https://example.com
APP_ADMIN_URL=admin
APP_TIMEZONE=UTC
APP_LOCALE=ru
APP_CURRENCY=RUB

# --- Domain & SSL ---
DOMAIN=example.com
SSL_EMAIL=admin@example.com

# --- MySQL ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bagisto
DB_USERNAME=bagisto
DB_PASSWORD=change_me_db_password
DB_ROOT_PASSWORD=change_me_root_password

# --- Redis ---
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=change_me_redis_password

# --- Cache / Session / Queue drivers ---
CACHE_STORE=redis
SESSION_DRIVER=redis
QUEUE_CONNECTION=redis

# --- Octane (RoadRunner) ---
APP_PORT=8000
OCTANE_WORKERS=auto
# RoadRunner release to install (https://github.com/roadrunner-server/roadrunner/releases)
RR_VERSION=2024.3.5

# --- Reverb (WebSockets) ---
REVERB_PORT=8080
REVERB_APP_ID=your_reverb_app_id
REVERB_APP_KEY=your_reverb_app_key
REVERB_APP_SECRET=your_reverb_app_secret
REVERB_HOST=0.0.0.0
REVERB_SCHEME=https

# --- Supervisor queue workers ---
QUEUE_PROCESSES=2

# --- Elasticsearch ---
ES_JAVA_HEAP=512m

# --- Node.js ---
NODE_MAJOR=20

# --- Migrations ---
# Set to true ONLY when you intentionally want migrations to run
RUN_MIGRATIONS=false

# --- Full Page Cache ---
RESPONSE_CACHE_ENABLED=true
RESPONSE_CACHE_DRIVER=redis

# --- Broadcast ---
BROADCAST_CONNECTION=reverb

# --- Optional integrations ---
YANDEX_MAPS_API_KEY=
GIGACHAT_CLIENT_ID=
GIGACHAT_CLIENT_SECRET=
OPENAI_API_KEY=
FCM_SERVER_KEY=

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=warning
